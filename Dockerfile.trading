# ---- Stage 1: Build compiled dependencies ----
FROM python:3.13-slim AS builder

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    python3-dev \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy shared directory first as it might be needed for some package installs
COPY shared /app/shared

WORKDIR /app/trading

COPY trading/requirements.txt ./
# Copy vendor if it exists
COPY trading/vendor* ./vendor/
RUN uv pip install --no-cache --system -r requirements.txt

# ---- Stage 2: Runtime (no compiler toolchain) ----
FROM python:3.13-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    && rm -rf /var/lib/apt/lists/*

# Bring over compiled packages from builder
COPY --from=builder /usr/local/lib/python3.13/site-packages /usr/local/lib/python3.13/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

WORKDIR /app

# Copy application code
COPY shared /app/shared
COPY trading /app/trading

# Install local packages (pure Python, no compilation needed)
WORKDIR /app/trading
# Check if types-py exists in shared and install it
RUN if [ -d "/app/shared/types-py" ]; then uv pip install --no-cache --system -e /app/shared/types-py; fi && \
    uv pip install --no-cache --system -e .

ENV PYTHONPATH=/app:$PYTHONPATH \
    PORT=8080

COPY trading/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["sh", "-c", "exec python3 -m uvicorn main:app --host 0.0.0.0 --port $PORT"]
