# Bittensor wallet keys (base64-encoded).
# Copy this file to .env.wallet and fill in your actual keys.
# NEVER commit .env.wallet to git.
#
# Generate these from your wallet files:
#   base64 -w0 ~/.bittensor/wallets/sta_wallet/coldkeypub.txt
#   base64 -w0 ~/.bittensor/wallets/sta_wallet/hotkeys/sta_hotkey

B64_COLDKEY_PUB=
B64_HOTKEY=
