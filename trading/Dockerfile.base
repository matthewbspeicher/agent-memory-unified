FROM python:3.12-slim

# Use uv for extremely fast dependency installation
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    tar \
    ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Copy and install opencli-rs from local archive
COPY opencli-rs.tar.gz /tmp/opencli-rs.tar.gz
RUN tar -xzf /tmp/opencli-rs.tar.gz -C /usr/local/bin && rm /tmp/opencli-rs.tar.gz

# Copy requirements and vendored dependencies
# Note: Using paths relative to project root since GH Actions uses root context
COPY python/requirements.txt requirements.txt
COPY python/vendor/ /app/vendor/

# Install dependencies using uv
RUN uv pip install --no-cache --system -r requirements.txt

# This image is intended to be a base for the stock-trading-api
LABEL description="Base image with pre-installed requirements and opencli-rs for Stock Trading API"
