# =============================================================================
# Stock Trading API — Environment Configuration
# =============================================================================
# Copy to .env and fill in values. All vars are prefixed STA_ in the env.
# Only the sections you use need values — everything has safe defaults.

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
# STA_BROKER_MODE=paper                    # "paper" (default) or "live"
# STA_API_KEY=                             # Required in live mode
# STA_API_HOST=127.0.0.1
# STA_API_PORT=8000
# STA_PAPER_TRADING=true
# STA_PAPER_TRADING_INITIAL_BALANCE=10000

# -----------------------------------------------------------------------------
# IBKR Connection
# -----------------------------------------------------------------------------
# STA_IB_HOST=127.0.0.1
# STA_IB_PORT=4002                         # 4002=paper, 4001=live (auto-set)
# STA_IB_CLIENT_ID=1

# -----------------------------------------------------------------------------
# Database (Shared Supabase PostgreSQL in Monorepo)
# -----------------------------------------------------------------------------
# Use the shared Supabase database from the monorepo root .env.example
# Get credentials from: Supabase Project Settings → Database → Connection pooling (Transaction mode)
# STA_DATABASE_URL=postgresql://postgres.tcumvviwzfernfoofwzh:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres
# STA_DATABASE_SSL=true
# STA_DATABASE_SSL_VERIFY=false            # Disable for pooler connections

# -----------------------------------------------------------------------------
# LLM Fallback Chain (Groq → Ollama → Anthropic → Rule-based)
# -----------------------------------------------------------------------------
# All keys are OPTIONAL. The system degrades gracefully:
#   - No keys at all → rule-based keyword scoring (free, always works)
#   - Groq key only  → Groq → rule-based (free tier: console.groq.com)
#   - All keys       → Groq → Ollama → Anthropic → rule-based
#
# RECOMMENDED ORDER (prioritizes free/cheap options first):
#   1. groq       — FREE tier (14k RPM, 8k TPM), fast Llama models
#   2. ollama     — FREE local inference, requires install
#   3. anthropic  — PAID, highest quality, use as fallback
#   4. rule-based — Always available, zero cost
#
# DEPLOYMENT NOTES:
#   - LOCAL (WSL2): Use Ollama with gemma4:e4b (9.6GB) for free local inference
#   - RAILWAY: Use Groq free tier only (Ollama needs GPU, not available on Railway)
#
# STA_ANTHROPIC_API_KEY=                   # Optional — paid, highest quality
# STA_GROQ_API_KEY=                        # Optional — FREE tier at console.groq.com
# STA_OLLAMA_BASE_URL=http://localhost:11434  # Optional — local, free, requires install
# STA_OLLAMA_MODEL=gemma4:e4b               # Gemma 4 E4B (9.6GB) — best quality/local
# STA_LLM_FALLBACK_CHAIN=["groq","ollama","anthropic","rule-based"]

# -----------------------------------------------------------------------------
# Kalshi Prediction Markets
# -----------------------------------------------------------------------------
# STA_KALSHI_KEY_ID=
# STA_KALSHI_PRIVATE_KEY_PATH=
# STA_KALSHI_DEMO=true                     # true=demo.kalshi.co, false=live

# -----------------------------------------------------------------------------
# Polymarket
# -----------------------------------------------------------------------------
# STA_POLYMARKET_PRIVATE_KEY=
# STA_POLYMARKET_FUNDER=
# STA_POLYMARKET_API_KEY=
# STA_POLYMARKET_DRY_RUN=true

# -----------------------------------------------------------------------------
# Alpaca
# -----------------------------------------------------------------------------
# STA_ALPACA_API_KEY=
# STA_ALPACA_SECRET_KEY=
# STA_ALPACA_PAPER=true

# -----------------------------------------------------------------------------
# BitGet (Crypto Exchange)
# -----------------------------------------------------------------------------
# STA_BITGET_API_KEY=
# STA_BITGET_SECRET_KEY=
# STA_BITGET_PASSPHRASE=

# -----------------------------------------------------------------------------
# Tradier
# -----------------------------------------------------------------------------
# STA_TRADIER_TOKEN=
# STA_TRADIER_ACCOUNT_ID=
# STA_TRADIER_SANDBOX=true

# -----------------------------------------------------------------------------
# WhatsApp (Hermes Assistant)
# -----------------------------------------------------------------------------
# STA_WHATSAPP_PHONE_ID=
# STA_WHATSAPP_TOKEN=
# STA_WHATSAPP_VERIFY_TOKEN=
# STA_WHATSAPP_APP_SECRET=
# STA_WHATSAPP_ALLOWED_NUMBERS=            # comma-separated

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
# STA_SLACK_WEBHOOK_URL=
# STA_SLACK_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# External Data
# -----------------------------------------------------------------------------
# STA_NEWSAPI_KEY=
# STA_NEWS_FEEDS=[]                        # JSON array of RSS feed URLs
# STA_NEWS_POLL_INTERVAL=90
# STA_ALPHA_VANTAGE_KEY=
# STA_COINGECKO_API_KEY=

# -----------------------------------------------------------------------------
# Supabase (Observability)
# -----------------------------------------------------------------------------
# STA_SUPABASE_URL=
# STA_SUPABASE_ANON_KEY=
# STA_SUPABASE_SERVICE_KEY=

# -----------------------------------------------------------------------------
# Remembr.dev (Memory API)
# -----------------------------------------------------------------------------
# STA_REMEMBR_BASE_URL=https://remembr.dev/api/v1
# STA_REMEMBR_API_KEY=
# STA_REMEMBR_SHARED_API_KEY=
# STA_REMEMBR_AGENT_TOKEN=

# -----------------------------------------------------------------------------
# Hardware & Performance
# -----------------------------------------------------------------------------
# STA_GPU_ENABLED=false
# STA_JOURNAL_INDEX_ENABLED=false
# STA_JOURNAL_INDEX_PERSIST_INTERVAL=300

# -----------------------------------------------------------------------------
# Arbitrage & Risk
# -----------------------------------------------------------------------------
# STA_ENABLE_ARBITRAGE=false
# STA_GOVERNOR_MAX_DRAWDOWN_PCT=5.0
# STA_GOVERNOR_MIN_SHARPE_PROMOTION=1.5

# -----------------------------------------------------------------------------
# JWT Authentication (Shared with Laravel API)
# -----------------------------------------------------------------------------
# JWT_SECRET=CHANGE_ME_TO_256_BIT_SECRET        # Must match api/.env
# JWT_ALGORITHM=HS256
# JWT_EXPIRY_MINUTES=15
