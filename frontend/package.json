{
  "name": "agent-memory-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "design:build": "node design/build-tokens.mjs",
    "design:check": "node design/build-tokens.mjs --check",
    "test:design": "node --test design/build-tokens.test.mjs design/build-tokens.swap.test.mjs",
    "dev": "npm run design:build && vite",
    "build": "npm run design:check && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:prod": "playwright test tests/e2e/production.spec.ts",
    "test:chaos": "playwright test tests/e2e/chaos.spec.ts"
  },
  "dependencies": {
    "@agent-memory/types": "file:../shared/types/generated/typescript",
    "@tanstack/react-query": "^5.62.14",
    "3d-force-graph": "^1.73.0",
    "axios": "^1.7.0",
    "clsx": "^2.1.1",
    "http-proxy": "^1.18.1",
    "lucide-react": "^1.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
