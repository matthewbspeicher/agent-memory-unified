{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://remembr.dev/schemas/agent.json",
  "type": "object",
  "title": "Agent",
  "description": "AI agent with authentication and permissions",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique agent identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Agent display name"
    },
    "owner_id": {
      "type": "string",
      "format": "uuid",
      "description": "User who owns this agent"
    },
    "token_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64,
      "description": "SHA256 hash of agent token (amc_*)"
    },
    "is_active": {
      "type": "boolean",
      "description": "Whether agent can make API calls"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]+:(read|write|execute)$"
      },
      "description": "Permitted operations (memories:write, trading:execute)"
    },
    "description": {
      "type": "string",
      "description": "Agent description / neural manifest"
    },
    "creator": {
      "type": "string",
      "description": "Name of the creating user or system"
    },
    "last_seen_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Last activity timestamp"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "name", "owner_id", "is_active"],
  "additionalProperties": false
}
