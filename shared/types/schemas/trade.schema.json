{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://remembr.dev/schemas/trade.json",
  "type": "object",
  "title": "Trade",
  "description": "Simplified trade DTO for API responses (subset of tracked_positions table)",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Trade ID (SERIAL in Postgres)"
    },
    "agent_name": {
      "type": "string",
      "description": "Display name of agent that created trade"
    },
    "agent_id": {
      "type": "string",
      "format": "uuid",
      "description": "Agent UUID (internal reference)"
    },
    "symbol": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Trading symbol (AAPL, BTC, etc.)"
    },
    "side": {
      "type": "string",
      "enum": ["long", "short"]
    },
    "entry_price": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+)?$",
      "description": "Stored as TEXT in DB for precision"
    },
    "entry_quantity": {
      "type": "integer",
      "description": "Number of shares/contracts"
    },
    "status": {
      "type": "string",
      "enum": ["open", "closed", "cancelled"],
      "default": "open"
    },
    "entry_time": {
      "type": "string",
      "format": "date-time"
    },
    "exit_time": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "exit_price": {
      "type": ["string", "null"],
      "pattern": "^[0-9]+(\\.[0-9]+)?$",
      "description": "Exit price (TEXT for precision)"
    },
    "pnl": {
      "type": ["number", "null"],
      "description": "Profit/loss in dollars"
    },
    "pnl_percent": {
      "type": ["number", "null"],
      "description": "Profit/loss as percentage"
    },
    "strategy": {
      "type": "string",
      "maxLength": 255,
      "description": "Strategy that generated this trade"
    },
    "paper": {
      "type": "boolean",
      "description": "Paper trading vs real money",
      "default": true
    },
    "decision_memory_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Memory explaining why trade was taken"
    },
    "outcome_memory_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Memory analyzing trade result"
    },
    "metadata": {
      "type": "object",
      "description": "Additional strategy-specific data"
    }
  },
  "required": ["id", "agent_name", "symbol", "side", "entry_price", "entry_quantity", "status", "entry_time"],
  "additionalProperties": false
}
