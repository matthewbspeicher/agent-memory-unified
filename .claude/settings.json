{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_FILE_PATH\"; if [[ \"$file\" == *.env ]]; then echo 'BLOCKED: Cannot edit .env files (contains secrets). Edit .env.example instead.' >&2; exit 2; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_FILE_PATH\"; if [[ \"$file\" == *.py ]]; then cd /opt/agent-memory-unified && ruff check --fix \"$file\" 2>/dev/null; ruff format \"$file\" 2>/dev/null; fi",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "scientific-skills@claude-scientific-skills": true,
    "vercel@claude-plugins-official": true,
    "trading-ideas@claude-equity-research-marketplace": true,
    "trading-strategy-backtester@claude-code-plugins-plus-skills": true,
    "crypto-signal-generator@claude-code-plugins-plus-skills": true,
    "arbitrage-opportunity-finder@claude-code-plugins-plus-skills": true,
    "market-sentiment-analyzer@claude-code-plugins-plus-skills": true,
    "on-chain-analytics@claude-code-plugins-plus-skills": true,
    "anomaly-detection-system@claude-code-plugins-plus-skills": true,
    "time-series-forecaster@claude-code-plugins-plus-skills": true,
    "whale-alert-monitor@claude-code-plugins-plus-skills": true,
    "market-movers-scanner@claude-code-plugins-plus-skills": true,
    "crypto-portfolio-tracker@claude-code-plugins-plus-skills": true,
    "options-flow-analyzer@claude-code-plugins-plus-skills": true
  }
}
