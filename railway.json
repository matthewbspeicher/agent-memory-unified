{
  "$schema": "https://railway.app/railway.schema.json",
  "experimentalServices": [
    {
      "name": "api",
      "rootDirectory": "api",
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "composer install --no-dev --optimize-autoloader && php artisan config:cache"
      },
      "deploy": {
        "region": "us-east-1",
        "startCommand": "php artisan octane:start --server=frankenphp --host=0.0.0.0 --port=$PORT",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10,
        "healthcheckPath": "/api/v1/health",
        "healthcheckTimeout": 100
      }
    },
    {
      "name": "trading",
      "rootDirectory": "trading",
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "pip install -e ."
      },
      "deploy": {
        "region": "us-east-1",
        "startCommand": "python3 -m uvicorn api.app:app --host 0.0.0.0 --port $PORT",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10,
        "healthcheckPath": "/health",
        "healthcheckTimeout": 100
      }
    },
    {
      "name": "frontend",
      "rootDirectory": "frontend",
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm install && npm run build"
      },
      "deploy": {
        "region": "us-east-1",
        "startCommand": "npx serve -s dist -l $PORT",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      }
    }
  ]
}
