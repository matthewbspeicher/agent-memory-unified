FROM node:20-alpine AS build

WORKDIR /app

# Copy root-level shared directory required by the frontend's @agent-memory/types dependency
COPY shared /app/shared

# Copy package files from frontend directory
COPY frontend/package.json frontend/package-lock.json* ./frontend/

# Install dependencies from frontend directory
WORKDIR /app/frontend
RUN npm ci

# Create .env file for build (Vite requires these to be baked in at build time)
# These will be overridden by Railway's build-time environment variables if they exist
ARG VITE_TRADING_API_URL
ARG VITE_TRADING_API_KEY
RUN echo "VITE_TRADING_API_URL=${VITE_TRADING_API_URL:-http://localhost:8080}" > .env.production && \
    echo "VITE_TRADING_API_KEY=${VITE_TRADING_API_KEY:-local-validator-dev}" >> .env.production

# Copy frontend application code
COPY frontend /app/frontend

# Build the application
RUN npm run build

# Production stage
FROM node:20-alpine

WORKDIR /app

# Copy built assets from the build stage.
COPY --from=build /app/frontend/dist ./dist

# Copy the production server (replaces `serve -s dist`). It proxies
# API paths (/api, /engine, /ready, /metrics, /stripe, /agents, /shadow,
# /health) to the trading backend so remembr.dev serves a real API
# response on those paths instead of falling through to index.html.
# SPA fallback preserved for every other path.
COPY frontend/server.mjs ./server.mjs

# Minimal runtime deps — only http-proxy is needed; the rest of the
# static-file logic uses Node's built-in http + fs modules. Avoids
# dragging in the full frontend devDependency tree for the server.
RUN npm install --omit=dev --no-audit --no-fund --save=false http-proxy@1.18.1

# Railway sets PORT. TRADING_UPSTREAM_URL is the backend target —
# defaults inside server.mjs to the Railway private DNS name
# (http://trading.railway.internal:8080). Override via Railway env var
# if needed.
CMD ["node", "server.mjs"]
